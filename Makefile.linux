# SDL2: use system-installed SDL2 dev package via pkg-config.
SDL_CFLAGS := $(shell pkg-config --cflags sdl2 2>/dev/null)
SDL_LIBS   := $(shell pkg-config --libs   sdl2 2>/dev/null)

ifeq ($(strip $(SDL_CFLAGS)),)
  $(error SDL2 development files not found. Install libsdl2-dev and pkg-config.)
endif

DEFINES += -DLUA_USE_POSIX
fpic := -fPIC

# SDL_LIBS typically already includes -lpthread on Linux, but keeping -lpthread is harmless.
LIBS += $(SDL_LIBS) -lpthread -lm
