pico-8 cartridge // http://www.pico-8.com
version 43
__lua__

-- test_print_scroll.p8
-- Regression test for print() cursor behaviour across:
--   * string lengths and content (plain, P8SCII wide/tall, repeat, custom width/height)
--   * print() with and without x,y coordinates
--   * 0x5f36 misc flags: 0x80 (char wrap), 0x40 (no scroll), 0x04 (no newline)
--   * 0x5f24 left margin
--   * uniform 8×8 custom font and variable-width custom font
--
-- Expected cursor values were captured from real Pico-8 by running:
--   ~/pico-8/pico8 -x gen_print_scroll.p8
-- Test cases are generated deterministically (srand(PSCROLL_SEED)) so the
-- same sequence is reproduced here.

#include test_fwk.lua
#include test_print_scroll_lib.lua

-- Override save() to avoid reset() clobbering custom-font state unexpectedly.
-- We replicate the p8scii test-cart pattern.
function save()
    memcpy(0x8000, 0, 0x5e00)
    memcpy(0xdf00, 0x5f00, 0x80)
    memcpy(0xe000, 0x6000, 0x2000)
    cls()
    cursor(0, 0)
    color(7)
end

