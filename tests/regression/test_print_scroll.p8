-- ── test suite ────────────────────────────────────────────────────────────────

function test_print_scroll()
    -- Generate all cases before entering test_case() so that save/restore of
    -- the RNG state (at 0x5f44) does not disturb the deterministic sequence.
    srand(PSCROLL_SEED)
    local cases = pscroll_generate_cases()

    for i = 1, #cases do
        local t   = cases[i]
        local exp = expected[i]

        -- Build a short human-readable name for failure messages.
        local name = "case_" .. i

        test_case(name, function()
            pscroll_run_case(t)
            local cx = peek(0x5f26)
            local cy = peek(0x5f27)
            if cx ~= exp[1] then
                fail("cx=" .. cx .. " expected " .. exp[1])
            end
            if cy ~= exp[2] then
                fail("cy=" .. cy .. " expected " .. exp[2])
            end
        end)
    end
end

function _init()
    test_suite("print_scroll", test_print_scroll)
    summary()
end
