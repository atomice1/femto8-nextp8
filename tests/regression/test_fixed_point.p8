pico-8 cartridge // http://www.pico-8.com
version 43
__lua__

#include test_fwk.lua

function test_fixed_point_literals()
    test_case("literal_round_trip", function()
        check_eq(tostr(0, true), "0x0000.0000")
        check_eq(tostr(1, true), "0x0001.0000")
        check_eq(tostr(-1, true), "0xffff.0000")
        check_eq(tostr(2, true), "0x0002.0000")
        check_eq(tostr(-2, true), "0xfffe.0000")

        check_eq(tostr(0x0.7fff, true), "0x0000.7fff")
        check_eq(tostr(0x0.8000, true), "0x0000.8000")
        check_eq(tostr(0x0.ffff, true), "0x0000.ffff")
        check_eq(tostr(0x7fff, true), "0x7fff.0000")
        check_eq(tostr(0x7fff.7fff, true), "0x7fff.7fff")
        check_eq(tostr(0x7fff.8000, true), "0x7fff.8000")
        check_eq(tostr(0x7fff.ffff, true), "0x7fff.ffff")
        check_eq(tostr(0x8000, true), "0x8000.0000")
        check_eq(tostr(0xffff.ffff, true), "0xffff.ffff")

        check_eq(tostr(-0x0.7fff, true), "0xffff.8001")
        check_eq(tostr(-0x0.8000, true), "0xffff.8000")
        check_eq(tostr(-0x0.ffff, true), "0xffff.0001")
        check_eq(tostr(-0x7fff, true), "0x8001.0000")
        check_eq(tostr(-0x7fff.7fff, true), "0x8000.8001")
        check_eq(tostr(-0x7fff.8000, true), "0x8000.8000")
        check_eq(tostr(-0x7fff.ffff, true), "0x8000.0001")
        check_eq(tostr(-0x8000, true), "0x8000.0000")
        check_eq(tostr(-0xffff.ffff, true), "0x0000.0001")
    end)
end

function test_fixed_point_arithmetic()
    test_case("addition_and_subtraction", function()
        check_eq(0x0.7fff + 0x0.8000, 0x0.ffff)
        check_eq(0x0.ffff + 1, 0x1.ffff)
        check_eq(0x7fff.7fff + 0x0.8000, 0x7fff.ffff)
        check_eq(0x7fff.ffff + 0x0.0001, -0x8000.0000)
        check_eq(-0x8000.0000 + 0x0.0001, -0x7fff.ffff)
        check_eq(0xffff.ffff + 1, 0x0.ffff)
        check_eq(-0xffff.ffff - 1, -0x0.ffff)
        check_eq(0x0.8000 - 1, -0x0.8000)
        check_eq(0x0.ffff - 0x0.ffff, 0)
        check_eq(0x8000.0000 - 0x0.0001, 0x7fff.ffff)
    end)

    test_case("multiplication_and_division", function()
        check_eq(0x0.8000 * 2, 1)
        check_eq(-0x0.8000 * 2, -1)
        check_eq(0xffff.ffff * 0x8000, 0x0.8000)
        check_eq(-0xffff.ffff * 0x8000, -0x0.8000)
        check_eq(1 / 2, 0x0.8000)
        check_eq(-1 / 2, -0x0.8000)
        check_eq(0x0.8000 / 0x0.8000, 1)
        check_eq(0x0.ffff / 0x0.ffff, 1)
        check_eq(0x7fff.8000 / 0x8000, -0x0.ffff)
        check_eq(-0x7fff.8000 / 0x8000, 0x0.ffff)
        check_eq(0x7fff \ 0x7fff, 1)
        check_eq(0xffff.ffff \ 1, -1)
        check_eq(0x7fff.ffff % 1, 0x0.ffff)
        check_eq(0xffff.ffff % 1, 0x0.ffff)
    end)
end

function test_fixed_point_math()
    test_case("min_max_mid", function()
        check_eq(max(0x7fff, 0x7fff.ffff), 0x7fff.ffff)
        check_eq(min(-0x7fff.8000, -0x7fff), -0x7fff.8000)
        check_eq(mid(-2, 0x0.8000, 2), 0x0.8000)
        check_eq(mid(-0x7fff, 0x0.ffff, 0x7fff), 0x0.ffff)
    end)

    test_case("floor_and_ceil", function()
        check_eq(flr(0x0.ffff), 0)
        check_eq(flr(-0x0.7fff), -1)
        check_eq(flr(-0x0.8000), -1)
        check_eq(ceil(0x0.7fff), 1)
        check_eq(ceil(0x0.8000), 1)
        check_eq(ceil(-0x0.7fff), 0)
        check_eq(ceil(-0x0.8000), 0)
    end)

    test_case("trigonometry", function()
        check_eq(cos(0), 1)
        check_eq(cos(0x0.8000), -1)
        check_eq(sin(0), 0)
        check_eq(sin(0x0.8000), 0)
        check_eq(atan2(1, 0), 0)
        check_eq(atan2(0, -1), 0.25)
        check_eq(atan2(-1, 0), 0.5)
        check_eq(atan2(0, 1), 0.75)
    end)

    test_case("sqrt_and_abs", function()
        check_eq(sqrt(0), 0)
        check_eq(sqrt(1), 1)
        check_eq(sqrt(0x0.8000 * 0x0.8000), 0x0.8000)
        check_eq(abs(-0x7fff.8000), 0x7fff.8000)
        check_eq(abs(-0xffff.ffff), 0x0.0001)
    end)

    test_case("sgn", function()
        check_eq(sgn(-0x0.0001), -1)
        check_eq(sgn(0), 1)
        check_eq(sgn(0x0.0001), 1)
    end)

    test_case("bitwise_and_shifts", function()
        check_eq(band(0b1010, 0b0110), 0B0010)
        check_eq(bor(0b1001, 0b1010), 0b1011)
        check_eq(bxor(0b101, 0b110), 0b011)
        check_eq(bnot(0b110), 0b1111111111111001.1111111111111111)
        check_eq(shl(0b101, 3), 0b101000)
        check_eq(shr(0b1111111111101000, 3), 0b1111111111111101)
        check_eq(lshr(0b101000, 3), 0b000101)
        check_eq(rotl(0b10100, 2), 0b1010000)
        check_eq(rotr(0b10100, 2), 0b00101)
    end)

    test_case("string_and_number_conversion", function()
        check_eq(tostr(17), "17")
        check_eq(tostr(17, 0x1), "0x0011.0000")
        check_eq(tostr(17, 0x2), "1114112")
        check_eq(tostr(17, 0x3), "0x00110000")
        check_eq(tonum("ff", 0x1), 255)
        check_eq(tonum("1114112", 0x2), 17)
        check_eq(tonum("1234abcd", 0x3), 0x1234.abcd)
        check_eq(tonum(true), 1)
        check_eq(tonum(false), 0)
        check_eq(chr(64), "@")
        check_eq(chr(104,101,108,108,111), "hello")
        check_eq(ord("@"), 64)
        check_eq(ord("123", 2), 50)
        check_eq({ord("123", 2, 3)}, {50, 51})
        check_eq(split(123), {123})
        check_eq(split("1,2,3"), {1, 2, 3})
        check_eq(split("one:two:3", ":", false), {"one", "two", "3"})
        check_eq(split("1,,2,"), {1, "", 2, ""})
    end)

    test_case("rnd_and_srand", function()
        srand(0xffff.ffff)
        local first_sample = rnd(0x7fff.ffff)
        local second_sample = rnd(0x7fff.ffff)

        check_ge(first_sample, 0)
        check_lt(first_sample, 0x7fff.ffff)
        check_ge(second_sample, 0)
        check_lt(second_sample, 0x7fff.ffff)

        srand(0xffff.ffff)
        check_eq(first_sample, rnd(0x7fff.ffff))
        check_eq(second_sample, rnd(0x7fff.ffff))
    end)
end

function _init()
    test_suite("fixed_point_arithmetic", function()
        test_fixed_point_literals()
        test_fixed_point_arithmetic()
        test_fixed_point_math()
    end)
    summary()
end
