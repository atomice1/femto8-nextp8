pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- Tests for tline() vertical line drawing with sprite row gradient.
-- Sprite 3 has row gradient (row n = color n).
-- Ported from: debug_tline

#include test_fwk.lua

function test_tline_vert()
    test_case("vert_row_gradient", function()
        camera(0,0)
        clip(0,0,128,128)
        pal()
        cls(15)
        poke(0x5f38, 0)
        poke(0x5f39, 0)
        poke(0x5f3a, 0)
        poke(0x5f3b, 0)
        for y=0,31 do
            for x=0,127 do
                mset(x, y, 0)
            end
        end
        mset(0, 0, 3) -- sprite 3: row gradient (row n = color n)
        tline(0, 0, 0, 7, 0, 0, 0, 0.125)
        -- y=0: row 0 is color 0 (transparent), so bg=15
        check_pixel(0, 0, 15, "row0_transparent")
        for y=1,7 do
            check_pixel(0, y, y, "row"..y)
        end
    end)
end

function _init()
    test_suite("tline_vert", test_tline_vert)
    summary()
end
