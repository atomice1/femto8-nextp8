function test_cos()
 for i=0,255 do
  local a=i/256
  local got=cos(a)
  local exp=ref_cos[i+1]
  if got!=exp then
   fail("cos("..tostr(a,true)..")"
    .." got="..tostr(got,true)
    .." exp="..tostr(exp,true))
  end
 end
end

function test_sin()
 for i=0,255 do
  local a=i/256
  local got=sin(a)
  local exp=ref_sin[i+1]
  if got!=exp then
   fail("sin("..tostr(a,true)..")"
    .." got="..tostr(got,true)
    .." exp="..tostr(exp,true))
  end
 end
end

function test_atan2_sweep()
 for i=0,255 do
  local dx=ref_cos[i+1]
  local dy=ref_sin[i+1]
  local got=atan2(dx,dy)
  local exp=ref_atan2[i+1]
  if got!=exp then
   fail("i="..i
    .." got="..tostr(got,true)
    .." exp="..tostr(exp,true))
  end
 end
end

function _init()
 test_suite("sin_cos", function()
  test_case("cos matches reference (256 angles)", test_cos)
  test_case("sin matches reference (256 angles)", test_sin)
 end)
 test_suite("atan2", function()
  test_case("atan2(1,0)=0", function()
   check_eq(atan2(1,0), 0)
  end)
  test_case("atan2(0,1)=0.75", function()
   check_eq(atan2(0,1), 0.75)
  end)
  test_case("atan2(-1,0)=0.5", function()
   check_eq(atan2(-1,0), 0.5)
  end)
  test_case("atan2(0,-1)=0.25", function()
   check_eq(atan2(0,-1), 0.25)
  end)
  test_case("atan2(1,-1)=0.125", function()
   check_eq(atan2(1,-1), 0.125)
  end)
  test_case("atan2(-1,-1)=0.375", function()
   check_eq(atan2(-1,-1), 0.375)
  end)
  test_case("atan2(-1,1)=0.625", function()
   check_eq(atan2(-1,1), 0.625)
  end)
  test_case("atan2(1,1)=0.875", function()
   check_eq(atan2(1,1), 0.875)
  end)
  test_case("256-angle sweep", test_atan2_sweep)
 end)
 summary()
end
