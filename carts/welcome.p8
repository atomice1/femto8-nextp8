pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
ang = 0
music(0)
function _update()
 ang += 1/150
end
function _draw()
 cls()
 print("welcome to", 44, 20)
 print("copy your carts to", 28, 110)
 print("/machines/nextp8/carts", 20, 116)
 local x=64
 local y=64
 local tx=0
 local ty=0
 local scale=2
 local tw=3
 local th=1
 local tcxo=0
 local tcyo=0
 scale*=8

 local ca,sa=cos(ang),-sin(ang)
 local tcx,tcy=
  tx+tcxo+tw/2,ty+tcyo+th/2

 local trad=max(
  sqrt((tx-tcx)^2+(ty-tcy)^2),
  sqrt((tx+tw-tcx)^2+(ty+th-tcy)^2))
 local prad=scale*trad

 local lns=1/scale
 local tstep,toffy=lns,-trad
 local tdx,tdy=ca*lns,sa*lns

 local costx=ca*-trad
 local sintx=sa*-trad

 for poffy=-prad,prad do
  local costy=ca*(toffy)
  local sinty=sa*(toffy)

  tline(
   x-prad,y+poffy,
   x+prad,y+poffy,
   tcx+costx-sinty,
   tcy+sintx+costy,
   tdx,tdy)

  toffy+=tstep
 end
end
